# .env.prod-db
#
# Credenciales para subir sesiones grabadas en LOCAL a producción.
# Usado solo por: scripts/upload_session.sh y scripts/sync_to_prod.py
# El backend y el Muse siempre graban contra las BBDDs LOCALES.
#
# Cómo usarlo:
#   1. cp .env.prod-db.example .env.prod-db
#   2. Rellena los valores de producción
#   3. ./scripts/upload_session.sh [--last | --id N | --all]
#
# NUNCA subas este archivo a git (está en .gitignore)

# ── BBDDs de PRODUCCIÓN (accedidas vía túnel SSH localhost:54XX) ──────────────
# El túnel mapea: localhost:5433 → api.random-lab.es:5432
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=brain_prototype
POSTGRES_USER=brain_user
POSTGRES_PASSWORD=FILL_ME

# El túnel mapea: localhost:8087 → api.random-lab.es:8086
INFLUX_URL=http://localhost:8087
INFLUX_TOKEN=FILL_ME
INFLUX_ORG=teoria-sintergica
INFLUX_BUCKET=eeg-data

# ── BBDDs LOCALES (para leer lo grabado) ─────────────────────────────────────
# (Si son los defaults no hace falta cambiarlos)
LOCAL_POSTGRES_HOST=localhost
LOCAL_POSTGRES_PORT=5432
LOCAL_POSTGRES_DB=brain_prototype
LOCAL_POSTGRES_USER=brain_user
LOCAL_POSTGRES_PASSWORD=sintergic2024

LOCAL_INFLUX_URL=http://localhost:8086
LOCAL_INFLUX_TOKEN=my-super-secret-auth-token
LOCAL_INFLUX_ORG=teoria-sintergica
LOCAL_INFLUX_BUCKET=eeg-data

# ── SSH (usado por tunnel-prod-db.sh y SCP de validation logs) ────────────────
PROD_SSH_HOST=api.random-lab.es
PROD_SSH_USER=root
PROD_VALIDATION_LOGS_DIR=/root/random/teoria-sintergica/brain-prototype/backend/validation_logs
